      if (label !== currentLabel) {
        groupedMessages.push({ type: 'label', label });
        currentLabel = label;
      }
      groupedMessages.push({
        type: 'message',
        _id: msg._id,
        senderId: msg.senderId,
        receiverId: msg.receiverId,
